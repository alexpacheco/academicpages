@PhdThesis{pacheco_ab,
author={Pacheco, Alexander B},
title={First principles dynamics of transient light absorption and emission of alkali atoms interacting with rare gas atoms},
year={2006},
publisher={University of Florida},
address={Gainesville, Fla},
keywords={Absorption clusters collision dynamics eikonal emission first induced molecular principles pseudopotentials spectra transient},
abstract={ABSTRACT: A first principles description of light emission and absorption during alkali-rare-gas atom interactions is developed using angular momentum dependent pseudopotentials and including two and three-body polarization terms. The treatment combines an eikonal (or short wavelength) approximation for the nuclear motion and time-dependent molecular orbitals to provide interatomic potentials, their non-adiabatic couplings and dipole moment during the interactions. The transient spectra for absorption and emission are obtained from the Fourier transform of the dipole moment. The spectrum obtained can be related to the difference potential between two electronic states during transition. To do this requires that the electronic potentials calculated during the dynamics are accurate. Our work can be divided into two parts. The first part involves the study of optical spectra during interactions of diatomic alkali-rare gas systems while the second part deals with the study of optical spectra of an alkali atom embedded in a cluster of rare gas atoms. For the first part, we study the optical spectra of LiHe at both hyperthermal and thermal energies. The potentials for the excited states obtained from angular momentum dependent pseudopotentials commonly used, are not accurate when compared to experimentally determined or ab-initio generated potentials and give incorrect spectra. We implement a method to obtain potentials very similar to ab-initio generated potentials; the new potentials give transient spectra in good agreement with experimentally measured spectra. Having validated our approach for diatomic alkali rare gas systems, we turn our attention to the dynamics and spectra of an alkali atom embedded in rare gas clusters. We first study the dynamics of an excited Li atom placed inside a cluster of He atoms and show how the atom moves to the surface. We then study the dynamics, populations and optical spectra for the excited atom initially at the surface, and with a velocity directed toward the surface of the cluster. We also study the effect of applying an electromagnetic field to the system including alteration of physical properties.},
note={Thesis (Ph.D.)--University of Florida, 2006.}
}



